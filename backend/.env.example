# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (dev):
DATABASE_URL=sqlite:///./zenhire.db
# Production PostgreSQL (Render/Supabase/Neon):
# DATABASE_URL=postgresql://user:password@host:5432/zenhire

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── ZendBX Storage (optional) ─────────────────────────────────────────────────
ZENDBX_ANON_KEY=your_zendbx_anon_key_here
ZENDBX_PROJECT_ID=your_zendbx_project_id_here
ZENDBX_PROJECT_SLUG=your_zendbx_project_slug_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# Example: https://zenhire.vercel.app,https://www.zenhire.in
ALLOWED_ORIGINS=
