# ── ZendBX SDK ───────────────────────────────────────────────────────────────
# Full URL to the ZendBX API. Must start with https://
# Example: https://api.zendbx.in  or  https://zendbx-2-zpp9.onrender.com
VITE_ZENDBX_URL=https://api.zendbx.in
VITE_ZENDBX_ANON_KEY=your_anon_key_here

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev:  leave blank (Vite proxy handles /local-api → localhost:8000/api)
# Production: https://your-backend.onrender.com/api
VITE_API_BASE_URL=
