# ── ZendBX (Auth + Storage) ──────────────────────────────────────────────────
VITE_ZENDBX_PROJECT_ID=your_project_id_here
VITE_ZENDBX_PROJECT_SLUG=your_project_slug_here
VITE_ZENDBX_ANON_KEY=your_anon_key_here

# ZendBX API URL
# Local dev:  leave blank (Vite proxy handles /api-proxy)
# Production: https://zendbx-2-zpp9.onrender.com/p/your_project_slug
VITE_ZENDBX_API_URL=

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev:  leave blank (Vite proxy handles /local-api → localhost:8000)
# Production: https://your-backend.onrender.com/api
VITE_API_BASE_URL=
